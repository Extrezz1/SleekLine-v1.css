/* HUD beside the triangle */
body::after {
  content: "SYS OK  |  [‚Ėą‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ]\A[‚Ėā‚ĖĄ‚ĖÖ‚Ėá‚Ėą‚Ėá‚ĖÖ‚ĖĄ‚Ėā]";
  white-space: pre;
  position: fixed;
  top: calc(50% - 10px);
  left: calc(50% + 60px);
  font-family: monospace;
  font-size: 12px;
  line-height: 1.1;
  color: rgba(255, 166, 59, 0.6);
  pointer-events: none;
  z-index: 11;
  animation: sl-hudbars 2.5s steps(1, end) infinite;
}

/* Sleekline ‚ÄĒ Scan Line (moved to html::after) */
@keyframes sl-scan {
  0%   { top: 100%; }
  50%  { top: 0%; }
  100% { top: 100%; }
}

@keyframes sl-distort {
  0% { filter: blur(0px); }
  50% { filter: blur(0.6px); }
  100% { filter: blur(0px); }
}

html::after {
  content: "";
  position: fixed;
  left: 0;
  width: 100%;
  height: 2px;
  background: rgba(255, 166, 59, 0.35);
  backdrop-filter: blur(1px);
  z-index: 9999;
  animation: sl-scan 4s linear infinite,
             sl-distort 4s steps(1, end) infinite;
  pointer-events: none;
}
